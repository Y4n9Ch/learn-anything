{
  "name": "learn-anything-cli",
  "version": "0.5.0",
  "description": "AI-powered recursive learning system with Socratic method and TDD practice",
  "keywords": [
    "learn-anything-cli",
    "learn-anything",
    "learning",
    "cli",
    "ai",
    "education",
    "socratic",
    "tdd"
  ],
  "homepage": "https://github.com/ChenChenyaqi/learn-anything",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChenChenyaqi/learn-anything"
  },
  "license": "MIT",
  "author": "yaqi chen",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "learn-anything": "./bin/learn-anything.js"
  },
  "files": [
    "dist",
    "bin",
    "!dist/**/*.test.js",
    "!dist/**/__tests__",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "node scripts/bundle-site.mjs && tsc",
    "site:bundle": "node scripts/bundle-site.mjs",
    "dev": "tsc --watch",
    "dev:cli": "pnpm build && node bin/learn-anything.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo 'Lint from root'",
    "prepublishOnly": "pnpm run build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.8.0",
    "chalk": "^5.5.0",
    "commander": "^14.0.0",
    "fast-glob": "^3.3.3",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "yaml": "^2.8.2",
    "zod": "^4.0.17"
  }
}
